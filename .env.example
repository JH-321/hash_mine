# Copy this file to .env and fill in real values. Never commit .env.

# Required
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_WITHOUT_FUNDS_YOU_CANNOT_RISK
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Transaction sending
# Leave FLASHBOTS_RPC empty to use the default Flashbots Protect endpoint when
# running `npm run mine:flashbots`.
# FLASHBOTS_RPC=https://rpc.flashbots.net/fast
# SEND_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_SEND_KEY
PRIORITY_GWEI=1
MAX_TIP_GWEI=4
GAS_LIMIT=200000

# CUDA miner binary. Set this when using a device-specific build.
# GPU_BIN=/home/elicer/hash_mine/cuda-miner/target/release/cuda-miner-a100
# GPU_BIN=/home/elicer/hash_mine/cuda-miner/target/release/cuda-miner-2080ti

# Single GPU
CUDA_DEVICE=0

# Multi-GPU. Uncomment for an 8-GPU rig; mine.js partitions nonce ranges.
# CUDA_DEVICES=0,1,2,3,4,5,6,7

# CUDA tuning defaults used by the current optimized kernel.
CUDA_BLOCK_THREADS=256
CUDA_BATCH_LOG2=28
CUDA_NONCES_PER_THREAD=1

# Epoch safety. With HASH's 100-block epochs, this stops stale searches before
# the boundary and waits for the next epoch automatically.
BLOCK_SECONDS=12
EPOCH_TIMEOUT_SAFETY_BLOCKS=2
BLOCK_WATCH_SECONDS=3

# Optional manual wall-clock timeout override. Usually leave unset.
# MINING_TIMEOUT_SECONDS=600

# CPU fallback only, used when no GPU binary exists.
# WORKERS=8
